# Firebase web app config (from Firebase console > Project settings > Your apps).
# When left blank, the app runs in "auth-disabled" dev mode (matches backend AUTH_REQUIRED=false).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Desmos graphing calculator API key (client-side embed key; safe to expose).
# Get one free at https://www.desmos.com/api
VITE_DESMOS_API_KEY=b1d25d77db4f4165aa3cbfb8d7d1658b

# Deployed backend URL. Leave BLANK for local dev (Vite proxies /api to
# localhost:8000, see vite.config.ts). REQUIRED in production (Vercel etc) —
# set to your deployed backend's public URL, no trailing slash, e.g.:
# VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=
