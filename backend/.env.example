# === Firebase ===
# Firebase project ID (used to validate the JWT 'aud' and 'iss' claims)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to the Firebase Admin service-account JSON (for Firestore access).
# Leave blank to run without persistence (solve/trace/explain still work).
GOOGLE_APPLICATION_CREDENTIALS=

# === Groq (natural-language explanation layer) ===
# Leave blank to disable US-007; symbolic steps still ship (degraded mode).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === App config ===
# Comma-separated allowed CORS origins (the frontend dev server + prod URL).
# In production, add your deployed frontend's origin(s), e.g. Vercel:
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173
# Hard wall-clock timeout (seconds) for a single symbolic solve (R-01)
SOLVE_TIMEOUT_SECONDS=3
# Max characters accepted in a raw expression string (R-01 pre-parse guard)
MAX_EXPRESSION_LENGTH=200
# Max AST node count accepted after parse (R-01 post-parse guard)
MAX_AST_NODES=200
# Recursion tracer hard caps (R-04)
MAX_TRACE_DEPTH=25
MAX_TRACE_NODES=500
# Set to "true" to require auth. When false (local dev without Firebase), a stub user is injected.
AUTH_REQUIRED=false
